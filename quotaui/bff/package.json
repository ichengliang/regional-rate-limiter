{
  "name": "quotaui-bff",
  "version": "0.0.0",
  "private": true,
  "description": "Backend-for-frontend for the quotaui admin console. See design/quotaui.md.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mock": "tsx dev/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
